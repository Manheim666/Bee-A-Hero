# Backend environment. Copy to .env and adjust.

# JWT signing secret — CHANGE THIS in any real deployment.
SECRET_KEY=dev-secret-change-me-please-0123456789

# Optional. When set, the assistant uses the real Anthropic API.
# When unset, a built-in mock provider answers so the demo never breaks.
ANTHROPIC_API_KEY=

# CORS origin for the Vite dev server.
FRONTEND_ORIGIN=http://localhost:5173
