# DroidCam MJPEG endpoint. Find your phone IP in the DroidCam app.
DROIDCAM_URL=http://192.168.1.100:4747/video

# One or more YOLO weights. Comma-separate for multi-model overlay
# (default runs a generic yolov8n so it works with zero setup).
# Example combining the repo's flower + insect detectors:
#   MODEL_PATHS=../data/interim/cv_runs/flower_det2_v2_yolo26m/weights/best.pt,../data/interim/cv_runs/insect_multidet_v2_yolo26m/weights/best.pt
MODEL_PATHS=yolov8n.pt

# Optional friendly labels for the models above (comma-separated, aligns 1:1).
# Shown on boxes as a colored prefix so flower vs insect stays visible.
MODEL_LABELS=

# Inference settings.
CONF_THRESHOLD=0.35
IMG_SIZE=640

# Reconnect delay when the DroidCam stream drops (seconds).
RECONNECT_DELAY=3.0

# JPEG quality of the streamed frames (1-100).
JPEG_QUALITY=80

# CPU-only by default; set to "cuda" or "mps" to accelerate.
DEVICE=cpu
